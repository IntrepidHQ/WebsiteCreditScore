# Copy to .env.local for local development (never commit secrets).

# --- Plan A: Supabase auth (at least URL + one key) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Use any ONE of these key names (Dashboard → Settings → API → anon / publishable):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Canonical site origin (OAuth redirects, absolute links). Match your deployed URL in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: server-only storage uploads (preview screenshots)
# SUPABASE_SERVICE_ROLE_KEY=

# Optional: Stripe (pricing)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Optional: hide demo workspace entry on production login when unset/false
# NEXT_PUBLIC_ENABLE_DEMO_WORKSPACE=false

# Optional: treat every workspace as pro — skip token deductions, high balance for new workspaces
# (Homepage audits use the public /audit route; this affects /app and token actions.)
WCS_UNLIMITED_WORKSPACE=true
