# Copy to .env.local for local development (never commit secrets).

# --- Plan A: Supabase auth (at least URL + one key) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Use any ONE of these key names (Dashboard → Settings → API → anon / publishable):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Canonical site origin (OAuth redirects, absolute links). Match your deployed URL in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Production: share Supabase auth between www and apex (fixes session-required when users
# hit both hosts). Example: AUTH_COOKIE_DOMAIN=.websitecreditscore.com
# AUTH_COOKIE_DOMAIN=

# Optional: server-only storage uploads (preview screenshots)
# SUPABASE_SERVICE_ROLE_KEY=

# Optional: Stripe (pricing)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Optional: hide demo workspace entry on production login when unset/false
# NEXT_PUBLIC_ENABLE_DEMO_WORKSPACE=false

# Optional: treat every workspace as pro — skip token deductions, high balance for new workspaces
# (Homepage audits use the public /audit route; this affects /app and token actions.)
WCS_UNLIMITED_WORKSPACE=true

# --- Screenshots ---
# Production (Vercel): VERCEL=1 disables local Playwright — you MUST set a Browserless token
# on the server or rely on PageSpeed (fragile without GOOGLE_PAGESPEED_API_KEY).
# Verify after deploy: GET https://YOUR_DOMAIN/api/health/screenshots → readyForServerlessCapture: true
#
# Primary token (any one of these names is read, in order):
# BROWSERLESS_API=
# BROWSERLESS_TOKEN=
# BROWSERLESS_KEY=
# Optional: override cluster; if unset we try production-sfo.browserless.io then chrome.browserless.io.
# BROWSERLESS_ENDPOINT=https://production-sfo.browserless.io

# Google PageSpeed Insights API key — recommended fallback on Vercel when Browserless errors.
# GOOGLE_PAGESPEED_API_KEY=

# --- AI-powered report analysis ---
# Anthropic API key — enables Claude-written business descriptions, executive
# summaries, audience profiles, and outreach email copy. Without this the app
# falls back to heuristic/template-based content generation.
# Uses model claude-haiku-4-5-20251001. Set on Vercel/hosting for production scans.
# ANTHROPIC_API_KEY=
