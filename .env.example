# Copy to .env.local and adjust.

# App URL (required for Stripe Checkout success/cancel URLs in production)
NEXT_PUBLIC_APP_URL=https://websitecreditscore.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Vercel Marketplace / legacy aliases are also supported by the app:
# SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_STORAGE_SUPABASE_URL=https://your-project.supabase.co
# STORAGE_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_STORAGE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# NEXT_PUBLIC_STORAGE_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SECRET_KEY=sb_secret_...
# Legacy service-role alias is also supported:
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# STORAGE_SUPABASE_SECRET_KEY=sb_secret_...
# STORAGE_SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Private salt for hashing IP/user-agent abuse signals. Use a long random value.
FREE_SCAN_HASH_SALT=replace-with-a-long-random-string

# Stripe (production)
STRIPE_SECRET_KEY=sk_live_...
# Vercel alias also supported by the app:
# STRIPE_SECRET=sk_live_...
# Webhook signing secret from Stripe Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Limited-time: start scans without Stripe (omit or set false in production)
# FREE_SCAN_MODE=true
# NEXT_PUBLIC_FREE_SCAN_MODE=true

# Preview-only scan-depth demo pages. Keep false in production unless intentionally guarded.
# NEXT_PUBLIC_ENABLE_SCAN_DEMOS=false

# ── SP Studio integration ────────────────────────────────────
# Shared 64-char hex secret with strategypresentation.com — generate with `openssl rand -hex 32`.
SP_WEBHOOK_SECRET=
# Endpoint that receives the strategy-creation webhook.
SP_WEBHOOK_URL=https://studio.strategypresentation.com/api/webhook

# ── Admin gate ───────────────────────────────────────────────
# Passphrase for /admin/login. Set a strong value; this gates the Promote-to-Strategy action.
ADMIN_PASSPHRASE=
