# Copy to .env.local for local development (never commit secrets).

# --- Plan A: Supabase auth (at least URL + one key) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Use any ONE of these key names (Dashboard → Settings → API → anon / publishable):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Canonical site origin (OAuth redirects, absolute links). Match your deployed URL in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: server-only storage uploads (preview screenshots)
# SUPABASE_SERVICE_ROLE_KEY=

# Optional: Stripe (pricing)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Optional: hide demo workspace entry on production login when unset/false
# NEXT_PUBLIC_ENABLE_DEMO_WORKSPACE=false

# Optional: treat every workspace as pro — skip token deductions, high balance for new workspaces
# (Homepage audits use the public /audit route; this affects /app and token actions.)
WCS_UNLIMITED_WORKSPACE=true

# --- Screenshots ---
# Browserless.io API token — primary live screenshot capture in production.
# Without this, the app falls back to Playwright (local only) then Google PageSpeed.
# BROWSERLESS_API=
# Optional: override the Browserless cluster endpoint (default: https://chrome.browserless.io)
# BROWSERLESS_ENDPOINT=https://chrome.browserless.io

# Google PageSpeed Insights API key — secondary screenshot fallback.
# Free tier works without a key but rate-limits quickly.
# GOOGLE_PAGESPEED_API_KEY=

# --- AI-powered report analysis ---
# Anthropic API key — enables Claude-written business descriptions, executive
# summaries, audience profiles, and outreach email copy. Without this the app
# falls back to heuristic/template-based content generation.
# ANTHROPIC_API_KEY=
